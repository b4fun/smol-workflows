{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "disableSizeLimit": true,
    "types": ["@smol-workflows/sdk"]
  },
  "include": ["*.mjs"]
}
