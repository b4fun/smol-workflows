@dataclass(frozen=True)
class AzureProfileConfig:
    """Configuration for one profile under `profiles.<name>` in config.json."""

    azure: AzureSandboxResource | None = config_field("Azure subscription/resource group/sandbox group coordinates. Example: {\"region\": \"eastus2\", \"subscription_id\": \"...\", \"resource_group\": \"my-rg\", \"sandbox_group\": \"my-sg\"}.")
    snapshot_id: str | None = config_field("Restore a sandbox from this snapshot ID. Example: \"00000000-0000-0000-0000-000000000000\".")
    disk_id: str | None = config_field("Create from this disk image ID. Example: \"disk-image-id\".")
    oci_image: OciImageSource | None = config_field("Build a temporary disk image from this OCI/container image, then create the sandbox from it. Example: {\"image\": \"ghcr.io/example/smol-agent:latest\"}.")
    preset: str | None = config_field("Create from this preset sandbox type. Example: \"python\".")
    disk: str | None = config_field("Public disk image name when no snapshot/disk_id/preset/oci_image is set. Example: \"ubuntu\".")
    cpu: str | None = config_field("CPU allocation. Example: \"1000m\".")
    memory: str | None = config_field("Memory allocation. Example: \"2048Mi\".")
    auto_suspend_seconds: int | None = config_field("Auto-suspend interval for newly created sandboxes. Example: 300.")
    cwd: str | None = config_field("Default working directory returned to smol-workflows. Example: \"/workspace\".")
    sync_workspace: bool | None = config_field("Whether to upload the workflow workspace on open. Example: false.")
    keep_on_close: bool | None = config_field("Debug/inspection escape hatch: leave the sandbox and any temporary disk image alive when the workflow closes the session. Example: true.")
    workspace_skip_dirs: list[str] | None = config_field("Directory names skipped during workspace upload. Example: [\".git\", \"node_modules\", \"target\"].")
    workspace_max_file_size: int | None = config_field("Max bytes per uploaded workspace file. Example: 4194304.")
    labels: dict[str, str] | None = config_field("Extra labels applied to newly created sandboxes. Example: {\"team\": \"workflow\"}.")
    environment: dict[str, str] | None = config_field("Environment variables applied at sandbox creation. Example: {\"FOO\": \"bar\"}.")
    connections: list[str] | None = config_field("Azure Sandbox connection names applied at creation. Example: [\"my-connection\"].")
    value_providers: dict[str, ValueProvider] | None = config_field(
        "Reusable value providers referenced by egress policy strings as `${value_providers.<name>}`. Example: {\"example_api_auth\": {\"command\": [\"sh\", \"-c\", \"printf 'Bearer example-token'\"]}}."
    )
    egress_policy: EgressPolicy | None = config_field(
        "Base Azure Sandbox egress policy (`defaultAction`, `trafficInspection`, `hostRules`, `rules`), using the Azure Sandbox Python SDK model shape. Header values may reference providers with `${value_providers.<name>}`. Example: {\"defaultAction\": \"Allow\", \"trafficInspection\": \"Partial\"}."
    )

    @classmethod
    def from_dict(cls, data: dict[str, Any], *, profile_name: str, path: Path) -> AzureProfileConfig:
        allowed = {field.name for field in fields(cls)}
        unknown = sorted(str(key) for key in data.keys() if key not in allowed)
        if unknown:
            raise ValueError(f"profile `{profile_name}` in {path} has unknown field(s): {', '.join(unknown)}")
        kwargs = dict(data)
        field_prefix = f"profile `{profile_name}`"
        require_optional_strings(
            kwargs,
            {
                "snapshot_id",
                "disk_id",
                "preset",
                "disk",
                "cpu",
                "memory",
                "cwd",
            },
            field_prefix,
        )
        require_optional_ints(
            kwargs,
            {
                "auto_suspend_seconds",
                "workspace_max_file_size",
            },
            field_prefix,
        )
        require_optional_bools(kwargs, {"sync_workspace", "keep_on_close"}, field_prefix)
        if kwargs.get("oci_image") is not None:
            kwargs["oci_image"] = OciImageSource.from_dict(
                require_object(kwargs["oci_image"], f"{field_prefix}.oci_image"),
                field_name=f"{field_prefix}.oci_image",
            )
        if kwargs.get("azure") is not None:
            kwargs["azure"] = AzureSandboxResource.from_dict(
                require_object(kwargs["azure"], f"{field_prefix}.azure"),
                field_name=f"{field_prefix}.azure",
            )
        if kwargs.get("workspace_skip_dirs") is not None:
            kwargs["workspace_skip_dirs"] = require_list_of_strings(
                kwargs["workspace_skip_dirs"], f"{field_prefix}.workspace_skip_dirs"
            )
        if kwargs.get("connections") is not None:
            kwargs["connections"] = require_list_of_strings(kwargs["connections"], f"{field_prefix}.connections")
        if kwargs.get("labels") is not None:
            kwargs["labels"] = require_dict_of_strings(kwargs["labels"], f"{field_prefix}.labels")
        if kwargs.get("environment") is not None:
            kwargs["environment"] = require_dict_of_strings(kwargs["environment"], f"{field_prefix}.environment")
        if kwargs.get("value_providers") is not None:
            raw_value_providers = require_object(kwargs["value_providers"], f"{field_prefix}.value_providers")
            kwargs["value_providers"] = {
                str(name): ValueProvider.from_dict(
                    require_object(value_provider, f"{field_prefix}.value_providers.{name}"),
                    field_name=f"{field_prefix}.value_providers.{name}",
                )
                for name, value_provider in raw_value_providers.items()
            }
        if kwargs.get("egress_policy") is not None:
            kwargs["egress_policy"] = EgressPolicy.from_dict(
                require_object(kwargs["egress_policy"], f"{field_prefix}.egress_policy"),
                field_name=f"{field_prefix}.egress_policy",
            )
        return cls(**kwargs)

    def to_dict(self) -> dict[str, Any]:
        data = asdict(self)
        if self.value_providers is not None:
            data["value_providers"] = {name: value_provider.to_dict() for name, value_provider in self.value_providers.items()}
        if self.egress_policy is not None:
            data["egress_policy"] = self.egress_policy.to_dict()
        return {key: value for key, value in data.items() if value is not None}


@dataclass(frozen=True)
class AzureProfile:
    name: str
    config: AzureProfileConfig

    @classmethod
    def load(cls, profile_name: str) -> AzureProfile:
        path = profile_config_path()
        if path.exists():
            config = read_profile_config(path)
            raw_profiles = config.get("profiles")
            if not isinstance(raw_profiles, dict):
                raise ValueError(f"config {path} must contain a `profiles` object")
            raw_profile = raw_profiles.get(profile_name)
            if raw_profile is None:
                available = ", ".join(sorted(str(name) for name in raw_profiles.keys()))
                raise ValueError(
                    f"profile `{profile_name}` not found in {path}; available profiles: {available or '(none)'}"
                )
            if not isinstance(raw_profile, dict):
                raise ValueError(f"profile `{profile_name}` in {path} must be a JSON object")
            return cls(profile_name, AzureProfileConfig.from_dict(raw_profile, profile_name=profile_name, path=path))

        raise FileNotFoundError(
            f"Azure sandbox config not found at {path}. Set CONFIG_BASE, pass --config, or create the profile config."
        )



